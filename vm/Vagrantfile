# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/jammy64"
  config.vm.hostname = "workshop-hacker"

  config.vm.provider "virtualbox" do |vb|
    vb.name   = "workshop-hacker-passwords"
    vb.memory = "2048"
    vb.cpus   = 2
  end

  # Partilha a pasta do desafio com a VM
  config.vm.synced_folder "../desafio", "/home/vagrant/desafio"

  config.vm.provision "shell", inline: <<-SHELL
    set -euo pipefail

    echo "[1/4] Atualizar lista de pacotes..."
    apt-get update -q

    echo "[2/4] Instalar hashcat..."
    apt-get install -y hashcat

    echo "[3/4] Instalar wordlists (rockyou)..."
    apt-get install -y wordlists
    if [ -f /usr/share/wordlists/rockyou.txt.gz ]; then
      gunzip /usr/share/wordlists/rockyou.txt.gz
    fi

    echo "[4/4] Verificar instalação..."
    hashcat --version
    ls -lh /usr/share/wordlists/rockyou.txt

    echo ""
    echo "VM pronta. Liga com: vagrant ssh"
    echo "Hashes disponíveis em: ~/desafio/"
  SHELL
end
